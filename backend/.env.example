# Copy to .env and customize. Consumed by docker compose and Spring Boot.
# Do NOT commit .env.

# Postgres (used by compose.yaml)
POSTGRES_DB=biotechcal
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Spring Boot (override application.properties)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/biotechcal
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres
SERVER_PORT=8080

# Comma-separated list of allowed origins for CORS
APP_CORS_ALLOWED_ORIGINS=http://localhost:4200
